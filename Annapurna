<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Annapurna Caterers</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
scroll-behavior:smooth;
}

body{
background:#fff;
color:#333;
}

header{
background:#111;
padding:20px 8%;
display:flex;
justify-content:space-between;
align-items:center;
position:sticky;
top:0;
z-index:999;
}

.logo{
color:#D4AF37;
font-size:28px;
font-weight:700;
}

nav a{
color:white;
margin-left:20px;
text-decoration:none;
}

.hero{
height:90vh;
background:linear-gradient(rgba(0,0,0,.65),rgba(0,0,0,.65)),
url('https://images.unsplash.com/photo-1555244162-803834f70033?auto=format&fit=crop&w=1400&q=80');
background-size:cover;
background-position:center;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
color:white;
padding:20px;
}

.hero h1{
font-size:60px;
}

.hero h2{
color:#D4AF37;
margin:15px 0;
}

.btn{
background:#D4AF37;
padding:14px 25px;
display:inline-block;
margin:10px;
text-decoration:none;
color:black;
font-weight:600;
border-radius:5px;
}

section{
padding:80px 8%;
}

.title{
text-align:center;
font-size:40px;
margin-bottom:40px;
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

.card{
background:#f5f5f5;
padding:25px;
border-radius:10px;
}

.card h3{
color:#D4AF37;
margin-bottom:10px;
}

.menu{
background:#111;
color:white;
}

.menu-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

.menu-box{
background:#222;
padding:25px;
border-radius:10px;
}

.booking{
background:#f7f7f7;
}

form{
max-width:700px;
margin:auto;
display:grid;
gap:15px;
}

input,select,textarea{
padding:15px;
border:1px solid #ccc;
border-radius:6px;
}

button{
background:#D4AF37;
border:none;
padding:15px;
font-size:16px;
cursor:pointer;
font-weight:600;
}

#result{
text-align:center;
font-size:25px;
margin-top:20px;
font-weight:bold;
}

.contact{
background:#111;
color:white;
text-align:center;
}

footer{
background:black;
color:white;
text-align:center;
padding:20px;
}

@media(max-width:768px){

.hero h1{
font-size:38px;
}

nav{
display:none;
}

}

</style>
</head>

<body>

<header>

<div class="logo">
ANNAPURNA CATERERS
</div>

<nav>
<a href="#about">About</a>
<a href="#services">Services</a>
<a href="#menu">Menu</a>
<a href="#booking">Booking</a>
<a href="#contact">Contact</a>
</nav>

</header>

<section class="hero">

<div>

<h1>Annapurna Caterers</h1>

<h2>25+ Years of Culinary Excellence</h2>

<p>From Intimate Gatherings to Grand Celebrations</p>

<a href="#booking" class="btn">Book Event</a>

<a href="tel:9963523137" class="btn">Call Now</a>

</div>

</section>

<section id="about">

<h2 class="title">About Us</h2>

<p style="text-align:center;font-size:18px;max-width:900px;margin:auto;">
For over 25 years, Annapurna Caterers has been serving Hyderabad with premium catering services for weddings, corporate events, birthday parties, outdoor events and live food counters.
</p>

</section>

<section id="services">

<h2 class="title">Our Services</h2>

<div class="cards">

<div class="card">
<h3>Wedding Catering</h3>
<p>Traditional and luxury wedding catering packages.</p>
</div>

<div class="card">
<h3>Corporate Events</h3>
<p>Professional catering for conferences and office events.</p>
</div>

<div class="card">
<h3>Birthday Parties</h3>
<p>Customized menus for all celebrations.</p>
</div>

<div class="card">
<h3>Outdoor Catering</h3>
<p>Large-scale outdoor catering management.</p>
</div>

<div class="card">
<h3>Live Counters</h3>
<p>Dosa, Chaat, BBQ, Mocktails and Ice Cream counters.</p>
</div>

</div>

</section>

<section id="menu" class="menu">

<h2 class="title">Menu Categories</h2>

<div class="menu-grid">

<div class="menu-box">
<h3>South Indian</h3>
Idli, Dosa, Vada, Pulihora, Pongal
</div>

<div class="menu-box">
<h3>North Indian</h3>
Paneer Butter Masala, Dal Makhani, Naan
</div>

<div class="menu-box">
<h3>Chinese</h3>
Noodles, Fried Rice, Manchurian
</div>

<div class="menu-box">
<h3>Sweets</h3>
Gulab Jamun, Rasmalai, Double Ka Meetha
</div>

</div>

</section>

<section id="booking" class="booking">

<h2 class="title">Instant Quote & Booking</h2>

<form>

<input type="text" placeholder="Full Name">

<input type="tel" placeholder="Mobile Number">

<input type="date">

<select id="event">
<option>Wedding</option>
<option>Reception</option>
<option>Birthday</option>
<option>Corporate Event</option>
</select>

<input type="number" id="guests" placeholder="Number of Guests">

<select id="pkg">
<option value="350">Silver Package</option>
<option value="500">Gold Package</option>
<option value="750">Platinum Package</option>
</select>

<textarea placeholder="Special Requirements"></textarea>

<button type="button" onclick="quote()">
Calculate Estimate
</button>

</form>

<div id="result"></div>

</section>

<section id="contact" class="contact">

<h2 class="title">Contact Us</h2>

<p><strong>R. Ashok Kumar</strong></p>

<p>📞 9963523137</p>

<p>📞 9618942934</p>

<p>📍 West Anand Bagh, Malkajgiri, Hyderabad</p>

<br>

<a href="https://wa.me/919963523137" class="btn">
WhatsApp Now
</a>

</section>

<footer>

Annapurna Caterers © 2026

<br>

25+ Years of Culinary Excellence

</footer>

<script>

function quote(){

let guests =
document.getElementById("guests").value;

let pkg =
document.getElementById("pkg").value;

let total = guests * pkg;

document.getElementById("result").innerHTML =
"Estimated Catering Cost: ₹" +
Number(total).toLocaleString();

}

</script>

</body>
</html>
